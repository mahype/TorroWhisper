      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Diagnose konnte nicht geschrieben werden." } }
      }
    },
    "Check accessibility access" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Zugriff prüfen" } }
      }
    },
    "Reset accessibility permission" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Berechtigung zurücksetzen" } }
      }
    },
    "Reset accessibility permission?" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Berechtigung zurücksetzen?" } }
      }
    },
    "Reset and reopen settings" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zurücksetzen und Einstellungen öffnen" } }
      }
    },
    "Accessibility access is granted." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Zugriff ist erteilt." } }
      }
    },
    "Accessibility access is missing. Enable TorroWhisper in System Settings." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Zugriff fehlt. Aktiviere TorroWhisper in den Systemeinstellungen." } }
      }
    },
    "If text insertion stops working even though TorroWhisper is listed under Accessibility, reset the permission and add the app again." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn das Einfügen von Text nicht mehr funktioniert, obwohl TorroWhisper unter Bedienungshilfen gelistet ist, setze die Berechtigung zurück und füge die App erneut hinzu." } }
      }
    },
    "This removes TorroWhisper from the Accessibility list so you can add it again. You will need to re-grant access afterwards." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dadurch wird TorroWhisper aus der Bedienungshilfen-Liste entfernt, damit du es erneut hinzufügen kannst. Du musst den Zugriff danach neu erteilen." } }
      }
    },
