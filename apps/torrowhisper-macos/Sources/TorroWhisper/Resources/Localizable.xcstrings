    "This profile uses: %@." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Dieses Profil nutzt: %@." } }
      }
    },
    "This shortcut is already reserved by macOS. Change it in System Settings under Keyboard › Keyboard Shortcuts, or pick a different combination." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Tastenkombination ist bereits als macOS-Systemshortcut reserviert. Ändere sie in den Systemeinstellungen unter Tastatur > Tastaturkurzbefehle oder wähle eine andere Kombination." } }
      }
    },
    "This shortcut is already used by TorroWhisper. If it is currently active, leave it unchanged or pick a new combination." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Tastenkombination wird in TorroWhisper bereits verwendet. Falls sie gerade aktiv ist, lasse sie unverändert oder wähle eine neue Kombination." } }
