    },
    "Diagnostics" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Diagnose" } }
      }
    },
    "TorroWhisper writes events and errors to a log file. Attach it when reporting problems." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "TorroWhisper schreibt Ereignisse und Fehler in eine Logdatei. Bei Problemberichten bitte anhängen." } }
      }
    },
    "Show log file in Finder" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Logdatei im Finder anzeigen" } }
      }
    },
