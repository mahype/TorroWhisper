    },
    "The shortcut could be tested but couldn't be released cleanly afterwards (OSStatus %d). Please try again." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Tastenkombination konnte getestet werden, ließ sich danach aber nicht sauber wieder freigeben (OSStatus %d). Bitte versuche es erneut." } }
      }
    },
    "This key is not currently supported as a global hotkey in the native macOS app." : {
      "localizations" : {
